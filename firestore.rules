/**
 * @file Vocaro Firestore Security Rules
 *
 * @core_philosophy This ruleset enforces a strict user-ownership model.  All data is nested under a user's document (`/users/{userId}`) and is only accessible to that user.
 * @data_structure All data is nested under `/users/{userId}`, including subjects, stacks, vocabulary, verbs, user settings, and learning sessions.
 * @key_security_decisions
 *   - User listing is disallowed.
 *   - Path-based ownership is used to ensure only the user can access their data.
 *   - No reliance on `get()` calls for authorization, all authorization can be done using path and `request.auth.uid`.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * @description Public profiles for user search and friend features.
     * @path /publicProfiles/{userId}
     * @allow (get, list) - Any authenticated user can read public profiles.
     * @allow (create, update) - Only the owner can create or update their own profile.
     * @deny (delete) - Profiles cannot be deleted.
     */
    match /publicProfiles/{userId} {
      allow get, list: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    /**
     * @description Manages friendships between users.
     * @path /friendships/{friendshipId}
     */
    match /friendships/{friendshipId} {
      function isParticipant() {
        return request.auth != null && (resource.data.requesterId == request.auth.uid || resource.data.recipientId == request.auth.uid);
      }

      function isFriendshipIdValid(recipientId) {
        let uid1 = request.auth.uid;
        let uid2 = recipientId;
        // Check if the friendshipId matches the client-side sorted order of the two UIDs
        return (uid1 < uid2 && friendshipId == uid1 + '_' + uid2) || 
               (uid2 < uid1 && friendshipId == uid2 + '_' + uid1);
      }
      
      // Allow GET if the user is a participant.
      allow get: if isParticipant();

      // Allow LIST for queries made by an authenticated user.
      // Client-side queries are responsible for fetching only relevant friendships.
      allow list: if request.auth != null;
      
      // Allow creating a friendship if the requester is the current user,
      // the status is pending, and the ID is correctly formed.
      allow create: if request.auth != null 
                    && request.resource.data.requesterId == request.auth.uid
                    && request.resource.data.status == 'pending'
                    && isFriendshipIdValid(request.resource.data.recipientId);

      // Allow the recipient to update the status from 'pending' to 'accepted'.
      // Only the 'status' field can be changed in this operation.
      allow update: if request.auth != null
                    && resource.data.recipientId == request.auth.uid
                    && resource.data.status == 'pending'
                    && request.resource.data.status == 'accepted'
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      
      // Allow either participant to delete the friendship (unfriend or cancel request).
      allow delete: if isParticipant();
    }

    /**
     * @description Protects the root `/users` collection. Only allows creating a user document with the ID matching the authenticated user's ID.
     * @path /users/{userId}
     * @allow (create) - Authenticated user creates their own user document.
     *   - auth.uid: "someUserId"
     *   - resource.data.id: "someUserId"
     * @deny (create) - Authenticated user attempts to create a user document for another user.
     *   - auth.uid: "someUserId"
     *   - resource.data.id: "anotherUserId"
     * @deny (get, list, update, delete) - All other operations are denied.
     * @principle Enforces user-ownership and prevents unauthorized access to user data.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    /**
     * @description Manages subjects created by the user. Only the authenticated user owning the subject can create, read, update, or delete it.
     * @path /users/{userId}/subjects/{subjectId}
     * @allow (create) - Authenticated user creates a subject under their user ID.
     *   - auth.uid: "someUserId"
     *   - path: /users/someUserId/subjects/newSubjectId
     * @allow (get, list) - Authenticated user reads their own subjects.
     *   - auth.uid: "someUserId"
     *   - path: /users/someUserId/subjects/existingSubjectId
     * @allow (update, delete) - Authenticated user updates or deletes their own subject.
     *   - auth.uid: "someUserId"
     *   - path: /users/someUserId/subjects/existingSubjectId
     * @deny (create, get, list, update, delete) - Any operation by a different user is denied.
     *   - auth.uid: "anotherUserId"
     *   - path: /users/someUserId/subjects/anySubjectId
     * @principle Enforces user-ownership for subjects, allowing only the owner to manage them.
     */
    match /users/{userId}/subjects/{subjectId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get, list, create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages vocabulary stacks within a subject. Only the authenticated user owning the stack can create, read, update, or delete it.
     * @path /users/{userId}/subjects/{subjectId}/stacks/{stackId}
     * @allow (create) - Authenticated user creates a stack under their subject.
     *   - auth.uid: "someUserId"
     *   - path: /users/someUserId/subjects/someSubjectId/stacks/newStackId
     * @allow (get, list) - Authenticated user reads their own stacks.
     *   - auth.uid: "someUserId"
     *   - path: /users/someUserId/subjects/someSubjectId/stacks/existingStackId
     * @allow (update, delete) - Authenticated user updates or deletes their own stack.
     *   - auth.uid: "someUserId"
     *   - path: /users/someUserId/subjects/someSubjectId/stacks/existingStackId
     * @deny (create, get, list, update, delete) - Any operation by a different user is denied.
     *   - auth.uid: "anotherUserId"
     *   - path: /users/someUserId/subjects/someSubjectId/stacks/anyStackId
     * @principle Enforces user-ownership for vocabulary stacks, allowing only the owner to manage them.
     */
    match /users/{userId}/subjects/{subjectId}/stacks/{stackId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get, list, create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages vocabulary words within a stack. Only the authenticated user owning the vocabulary can create, read, update, or delete it.
     * @path /users/{userId}/subjects/{subjectId}/stacks/{stackId}/vocabulary/{vocabularyId}
     * @allow (create) - Authenticated user creates a vocabulary word under their stack.
     *   - auth.uid: "someUserId"
     *   - path: /users/someUserId/subjects/someSubjectId/stacks/someStackId/vocabulary/newVocabId
     * @allow (get, list) - Authenticated user reads their own vocabulary words.
     *   - auth.uid: "someUserId"
     *   - path: /users/someUserId/subjects/someSubjectId/stacks/someStackId/vocabulary/existingVocabId
     * @allow (update, delete) - Authenticated user updates or deletes their own vocabulary word.
     *   - auth.uid: "someUserId"
     *   - path: /users/someUserId/subjects/someSubjectId/stacks/someStackId/vocabulary/existingVocabId
     * @deny (create, get, list, update, delete) - Any operation by a different user is denied.
     *   - auth.uid: "anotherUserId"
     *   - path: /users/someUserId/subjects/someSubjectId/stacks/someStackId/vocabulary/anyVocabId
     * @principle Enforces user-ownership for vocabulary words, allowing only the owner to manage them.
     */
    match /users/{userId}/subjects/{subjectId}/stacks/{stackId}/vocabulary/{vocabularyId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get, list, create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages verbs for a subject. Only the authenticated user owning the verb can create, read, update, or delete it.
     * @path /users/{userId}/subjects/{subjectId}/verbs/{verbId}
     * @allow (create) - Authenticated user creates a verb under their subject.
     *   - auth.uid: "someUserId"
     *   - path: /users/someUserId/subjects/someSubjectId/verbs/newVerbId
     * @allow (get, list) - Authenticated user reads their own verbs.
     *   - auth.uid: "someUserId"
     *   - path: /users/someUserId/subjects/someSubjectId/verbs/existingVerbId
     * @allow (update, delete) - Authenticated user updates or deletes their own verb.
     *   - auth.uid: "someUserId"
     *   - path: /users/someUserId/subjects/someSubjectId/verbs/existingVerbId
     * @deny (create, get, list, update, delete) - Any operation by a different user is denied.
     *   - auth.uid: "anotherUserId"
     *   - path: /users/someUserId/subjects/someSubjectId/verbs/anyVerbId
     * @principle Enforces user-ownership for verbs, allowing only the owner to manage them.
     */
    match /users/{userId}/subjects/{subjectId}/verbs/{verbId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get, list, create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages user settings. Only the authenticated user can create, read, update, or delete their settings.
     * @path /users/{userId}/settings/{settingsId}
     * @allow (create) - Authenticated user creates their settings document.
     *   - auth.uid: "someUserId"
     *   - path: /users/someUserId/settings/newSettingsId
     * @allow (get, list) - Authenticated user reads their own settings.
     *   - auth.uid: "someUserId"
     *   - path: /users/someUserId/settings/existingSettingsId
     * @allow (update, delete) - Authenticated user updates or deletes their settings.
     *   - auth.uid: "someUserId"
     *   - path: /users/someUserId/settings/existingSettingsId
     * @deny (create, get, list, update, delete) - Any operation by a different user is denied.
     *   - auth.uid: "anotherUserId"
     *   - path: /users/someUserId/settings/anySettingsId
     * @principle Enforces user-ownership for settings, allowing only the owner to manage them.
     */
    match /users/{userId}/settings/{settingsId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get, list, create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages learning sessions for the user. Only the authenticated user can create, read, update, or delete their learning sessions.
     * @path /users/{userId}/learningSessions/{learningSessionId}
     * @allow (create) - Authenticated user creates a learning session under their user ID.
     *   - auth.uid: "someUserId"
     *   - path: /users/someUserId/learningSessions/newSessionId
     * @allow (get, list) - Authenticated user reads their own learning sessions.
     *   - auth.uid: "someUserId"
     *   - path: /users/someUserId/learningSessions/existingSessionId
     * @allow (update, delete) - Authenticated user updates or deletes their own learning session.
     *   - auth.uid: "someUserId"
     *   - path: /users/someUserId/learningSessions/existingSessionId
     * @deny (create, get, list, update, delete) - Any operation by a different user is denied.
     *   - auth.uid: "anotherUserId"
     *   - path: /users/someUserId/learningSessions/anySessionId
     * @principle Enforces user-ownership for learning sessions, allowing only the owner to manage them.
     */
    match /users/{userId}/learningSessions/{learningSessionId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get, list, create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages vocabulary learned in learning sessions. Only the authenticated user can create, read, update, or delete vocabulary within their learning sessions.
     * @path /users/{userId}/learningSessions/{learningSessionId}/vocabulary/{vocabularyId}
     * @allow (create) - Authenticated user creates a learning session vocabulary under their learning session.
     *   - auth.uid: "someUserId"
     *   - path: /users/someUserId/learningSessions/someSessionId/vocabulary/newVocabId
     * @allow (get, list) - Authenticated user reads their own learning session vocabulary.
     *   - auth.uid: "someUserId"
     *   - path: /users/someUserId/learningSessions/someSessionId/vocabulary/existingVocabId
     * @allow (update, delete) - Authenticated user updates or deletes their own learning session vocabulary.
     *   - auth.uid: "someUserId"
     *   - path: /users/someUserId/learningSessions/someSessionId/vocabulary/existingVocabId
     * @deny (create, get, list, update, delete) - Any operation by a different user is denied.
     *   - auth.uid: "anotherUserId"
     *   - path: /users/someUserId/learningSessions/someSessionId/vocabulary/anyVocabId
     * @principle Enforces user-ownership for learning session vocabulary, allowing only the owner to manage them.
     */
    match /users/{userId}/learningSessions/{learningSessionId}/vocabulary/{vocabularyId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get, list, create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages verb answers in learning sessions. Only the owner can manage them.
     * @path /users/{userId}/learningSessions/{learningSessionId}/verbAnswers/{verbAnswerId}
     */
    match /users/{userId}/learningSessions/{learningSessionId}/verbAnswers/{verbAnswerId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get, list, create: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }
  }
}

    