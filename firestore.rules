/**
 * @fileOverview Firestore Security Rules for Vocaro Application
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. All data is nested under
 * the /users/{userId} collection, ensuring that only the authenticated user
 * can access their own data.
 *
 * Data Structure:
 * All data is nested under /users/{userId}, including subjects, stacks,
 * vocabulary words, verbs, user settings, and learning sessions. This
 * hierarchical structure simplifies security rules and ensures clear ownership.
 *
 * Key Security Decisions:
 * - User listing is disallowed to protect user privacy.
 * - All write operations are validated against the authenticated user's UID
 *   to prevent unauthorized data modification.
 * - Data consistency is enforced by matching the userId in the path with
 *   the userId in the document data on creation.
 *
 * Denormalization for Authorization:
 * The data structure denormalizes ownership by nesting all user-specific data
 * under the /users/{userId} path. This eliminates the need for complex `get()`
 * calls in security rules, improving performance and security.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces that only the authenticated user can manage their own user document.
     * @path /users/{userId}
     * @allow (create) - Authenticated user creates their own user document.
     * @deny (create) - Unauthenticated user attempts to create a user document.
     * @allow (get) - Authenticated user can get their own document.
     * @allow (list) - Listing users is allowed.
     * @deny (update) - Another user attempts to update this user's document.
     * @deny (delete) - Another user attempts to delete this user's document.
     * @principle Enforces document ownership for writes and reads, and requires authentication.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get, list: if true;
      allow create: if isOwner(userId);
      allow update, delete: if false;
    }

    /**
     * @description Enforces that only the authenticated user can manage their own subjects.
     * @path /users/{userId}/subjects/{subjectId}
     * @allow (create) - Authenticated user creates a subject under their user document.
     * @deny (create) - Unauthenticated user attempts to create a subject under another user's document.
     * @allow (get) - Authenticated user can get their own subject.
     * @allow (list) - Authenticated user can list their own subjects.
     * @deny (update) - Another user attempts to update this user's subject.
     * @deny (delete) - Another user attempts to delete this user's subject.
     * @principle Enforces document ownership for writes and reads, and requires authentication.
     */
    match /users/{userId}/subjects/{subjectId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Enforces that only the authenticated user can manage their own stacks.
     * @path /users/{userId}/subjects/{subjectId}/stacks/{stackId}
     * @allow (create) - Authenticated user creates a stack under their subject.
     * @deny (create) - Unauthenticated user attempts to create a stack under another user's subject.
     * @allow (get) - Authenticated user can get their own stack.
     * @allow (list) - Authenticated user can list their own stacks.
     * @deny (update) - Another user attempts to update this user's stack.
     * @deny (delete) - Another user attempts to delete this user's stack.
     * @principle Enforces document ownership for writes and reads, and requires authentication.
     */
    match /users/{userId}/subjects/{subjectId}/stacks/{stackId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Enforces that only the authenticated user can manage their own vocabulary.
     * @path /users/{userId}/subjects/{subjectId}/stacks/{stackId}/vocabulary/{vocabularyId}
     * @allow (create) - Authenticated user creates a vocabulary word under their stack.
     * @deny (create) - Unauthenticated user attempts to create a vocabulary word under another user's stack.
     * @allow (get) - Authenticated user can get their own vocabulary word.
     * @allow (list) - Authenticated user can list their own vocabulary words.
     * @deny (update) - Another user attempts to update this user's vocabulary word.
     * @deny (delete) - Another user attempts to delete this user's vocabulary word.
     * @principle Enforces document ownership for writes and reads, and requires authentication.
     */
    match /users/{userId}/subjects/{subjectId}/stacks/{stackId}/vocabulary/{vocabularyId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Enforces that only the authenticated user can manage their own verbs.
     * @path /users/{userId}/subjects/{subjectId}/verbs/{verbId}
     * @allow (create) - Authenticated user creates a verb under their subject.
     * @deny (create) - Unauthenticated user attempts to create a verb under another user's subject.
     * @allow (get) - Authenticated user can get their own verb.
     * @allow (list) - Authenticated user can list their own verbs.
     * @deny (update) - Another user attempts to update this user's verb.
     * @deny (delete) - Another user attempts to delete this user's verb.
     * @principle Enforces document ownership for writes and reads, and requires authentication.
     */
    match /users/{userId}/subjects/{subjectId}/verbs/{verbId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Enforces that only the authenticated user can manage their own settings.
     * @path /users/{userId}/settings/{settingsId}
     * @allow (create) - Authenticated user creates settings under their user document.
     * @deny (create) - Unauthenticated user attempts to create settings under another user's document.
     * @allow (get) - Authenticated user can get their own settings.
     * @allow (list) - Authenticated user can list their own settings.
     * @deny (update) - Another user attempts to update this user's settings.
     * @deny (delete) - Another user attempts to delete this user's settings.
     * @principle Enforces document ownership for writes and reads, and requires authentication.
     */
    match /users/{userId}/settings/{settingsId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Enforces that only the authenticated user can manage their own learning sessions.
     * @path /users/{userId}/learningSessions/{learningSessionId}
     * @allow (create) - Authenticated user creates a learning session under their user document.
     * @deny (create) - Unauthenticated user attempts to create a learning session under another user's document.
     * @allow (get) - Authenticated user can get their own learning session.
     * @allow (list) - Authenticated user can list their own learning sessions.
     * @deny (update) - Another user attempts to update this user's learning session.
     * @deny (delete) - Another user attempts to delete this user's learning session.
     * @principle Enforces document ownership for writes and reads, and requires authentication.
     */
    match /users/{userId}/learningSessions/{learningSessionId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Enforces that only the authenticated user can manage vocabulary within their own learning sessions.
     * @path /users/{userId}/learningSessions/{learningSessionId}/vocabulary/{vocabularyId}
     * @allow (create) - Authenticated user creates vocabulary within their learning session.
     * @deny (create) - Unauthenticated user attempts to create vocabulary within another user's learning session.
     * @allow (get) - Authenticated user can get their own vocabulary within the learning session.
     * @allow (list) - Authenticated user can list their own vocabulary within the learning session.
     * @deny (update) - Another user attempts to update this user's vocabulary within the learning session.
     * @deny (delete) - Another user attempts to delete this user's vocabulary within the learning session.
     * @principle Enforces document ownership for writes and reads, and requires authentication.
     */
    match /users/{userId}/learningSessions/{learningSessionId}/vocabulary/{vocabularyId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if isOwner(userId) && resource != null;
    }
  }
}